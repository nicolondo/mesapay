generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  tagline   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Group ownership — opcional. Cuando un dueño tiene varios
  // restaurantes los agrupa bajo un Group y crea usuarios
  // group_admin que ven todos sus locales en /group. Restaurantes
  // sin grupo (la mayoría hoy) tienen groupId=null y funcionan
  // exactamente como antes.
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Razón social. Por defecto los datos legales/DIAN viven en
  // las columnas legales* de este modelo (back-compat). Si se asigna
  // un LegalEntity del grupo, ese GANA al hidratar la factura — el
  // restaurante "hereda" razón social + numeración DIAN compartida
  // con sus hermanas del grupo.
  legalEntityId String?
  legalEntity   LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)

  // Modo de menú dentro del grupo:
  //   "independent"        — menú propio, sin sincronización (default).
  //   "synced_from_group"  — items se clonan/sincronizan del menú
  //                           maestro del grupo. Implementación de
  //                           sync queda para fase 2; este campo
  //                           se introduce ya para tener el flag.
  menuMode String @default("independent")

  plan               Plan      @default(trial)
  monthlyPriceCents  Int       @default(0)
  periodEndsAt       DateTime?
  suspended          Boolean   @default(false)
  // Última vez que el cron envió un recordatorio de vencimiento.
  // Lo usa /api/cron/membership-reminders para no spamear — solo
  // re-envía si pasó >= 1 día desde el último o si cambió de
  // "umbral" (T-7 → T-3 → T-0 → vencido).
  lastReminderSentAt DateTime?
  // Etiqueta del último umbral mandado: "T-7" | "T-3" | "T-0" |
  // "overdue" | "suspended". Permite re-enviar cuando cruzamos a
  // un umbral distinto aunque haya pasado < 1d.
  lastReminderKind   String?

  // Umbral en minutos para el cálculo de walkout-risk en la vista
  // Mesas. Default 20 = una mesa con todos los items entregados y
  // sin pagar pasa a "danger" después de 20min. Watch/warn se
  // derivan como fracciones (25%/50%). Para requests pendientes
  // (cobro pedido, mesero llamado) el umbral efectivo es la
  // mitad — son señales más urgentes. Configurable por comercio
  // porque depende del tipo: fine-dining tolera sobremesa larga,
  // casual-fast no.
  walkoutDangerMinutes Int @default(20)

  serviceMode         ServiceMode @default(table)
  pickupEnabled       Boolean     @default(false)
  pickupHours         Json?
  pickupMaxEtaMinutes Int?        @default(45)

  // Kushki sub-merchant credentials. publicKey is safe to expose to the
  // browser SDK; privateKeyEnc + webhookSecretEnc son AES-GCM ciphertext
  // (src/lib/crypto.ts). El webhook secret es el que Kushki usa para
  // firmar las llamadas HMAC al endpoint /api/webhooks/kushki — cada
  // sub-merchant puede tener su propio secreto en producción.
  kushkiMerchantId          String?
  kushkiPublicKey           String?
  kushkiPrivateKeyEnc       String?
  kushkiWebhookSecretEnc    String?
  // Business code del comercio en el Cloud Terminal API (datáfono físico
  // vía cloud). Lo carga el comercio desde Configuración → Datáfonos. Va
  // en el cuerpo del push a cloudt.kushkipagos.com. La credencial de auth
  // (X-BP-AUTH) es a nivel plataforma (env), este código rutea al comercio.
  cloudTerminalBusinessCode String?
  // Modo Kushki por comercio: "mock" | "sandbox" | "production". Null =
  // hereda el modo global de PlatformConfig.kushkiMode. Controla a qué
  // host (uat vs prod) van TODAS las operaciones de pago de este comercio
  // —tarjeta, PSE, Apple Pay y el datáfono cloud— y si se usa el provider
  // mock o el real. Editable por comercio desde /admin/restaurants/[id]/pagos.
  kushkiMode                String?
  // 3DS en pagos con tarjeta del comensal: si true, la tokenización pide
  // authValidation:"url" y el diner pasa por el OTP del banco cuando la
  // tarjeta lo requiere. Editable desde /admin/restaurants/[id]/pagos.
  kushkiCard3ds             Boolean                @default(true)
  // Pulso (asistente de IA): override por comercio del gating por plan.
  // null = según plan (trial/pro habilitados, basic no). true/false = forzar.
  aiInsightsEnabled         Boolean?
  // Límite de mensajes/día del asistente para este comercio. null = usar el
  // default global de PlatformConfig.aiDailyMessageLimit.
  aiDailyMessageLimit       Int?
  // Relaciones de Pulso
  aiConversations           AiConversation[]
  searchEvents              SearchEvent[]
  kushkiOnboardingStatus    KushkiOnboardingStatus @default(not_started)
  kushkiOnboardingNotes     String?
  kushkiSubmittedAt         DateTime?
  kushkiActivatedAt         DateTime?

  // Bank info — populated by AI OCR of the bank certification then verified
  // by the operator. Shape: BankInfo (see src/lib/payments/types.ts).
  bankInfo           Json?
  autoDispersePolicy Json?

  // Lista de etiquetas para platos del restaurante. Shape:
  // [{ slug: string, label: string, emoji?: string }]. Cuando es null
  // se aplican los defaults (firma, popular, veg, spicy, nuevo) — ver
  // src/lib/menuTags.ts. Los operadores pueden crear / renombrar /
  // eliminar desde /operator/settings/etiquetas.
  menuTags Json?

  // Medios de pago habilitados para este comercio (toggles en
  // /admin/restaurants/[id]). Shape: string[] de slugs como
  // "kushki_card_terminal", "kushki_apple_pay", "cash". Null = todos
  // habilitados (back-compat para comercios existentes). Una lista
  // vacía explícita = ninguno permitido (raro pero válido).
  enabledPaymentMethods Json?

  // Módulos ERP activados para este comercio (array de slugs — ver
  // src/lib/modules.ts). null/[] = ninguno: los módulos administrativos
  // (inventario, compras, recetas, facturación electrónica, contabilidad…)
  // son OPT-IN por comercio; los activa el admin de plataforma según lo
  // contratado. Un comercio con su propio ERP los deja apagados.
  enabledModules Json?

  // ─── Reservas ───────────────────────────────────────────────────
  // Toggle global del feature por comercio. Default false porque
  // los restaurantes existentes no la tienen configurada y queremos
  // que activen explícitamente desde /operator/settings/reservas
  // (que aparece sólo cuando el módulo está prendido).
  reservationsEnabled       Boolean       @default(false)
  // Config JSON con turnos por día, duración del slot, auto-confirm,
  // anticipación mínima, etc. Shape: ReservationConfig (ver
  // src/lib/reservations.ts). Null = usar defaults del helper.
  reservationConfig         Json?
  // Plano del salón: grilla (cols/rows) + zonas (jardín, terraza,
  // interior…) + markers (entrada, baños, barra…). Las posiciones de
  // las mesas siguen en Table.floorPlanX/Y. Shape: FloorPlan (ver
  // src/lib/floorPlan.ts). Null = grilla por defecto sin zonas.
  floorPlan                 Json?
  // Qué medios de pago se ofrecen para el DEPÓSITO de reserva. Subconjunto
  // de los métodos online del comercio (tarjeta/PSE/Apple Pay) — efectivo
  // y datáfono no sirven para apartar a distancia. Array de slugs (ver
  // src/lib/paymentMethods.ts). Null = todos los online habilitados.
  reservationDepositMethods Json?
  reservations              Reservation[]

  // Does this restaurant have a dedicated bartender / barista (separate
  // person from cooks)? Controls whether items routed to station=bar get
  // their own board at /operator/bar, or fall through as "grab from the
  // bar" tickets in the waiter's serve view.
  hasBar Boolean @default(false)

  // Optional sub-station labels within the bar — e.g. ["Cocteles",
  // "Cervezas", "Café"]. When non-empty, each bar category can pick
  // which sub-station it belongs to via Category.barSubStation, and the
  // /operator/bar board surfaces tabs to filter. Empty list = single
  // unified bar board.
  barSubStations String[] @default([])

  // Physical printing config. When *PrintEnabled is true the server
  // emits SSE "ticket.printable" events at the right transitions; an
  // operator opens /operator/print/{station} on the kitchen/bar
  // computer (with a USB or network thermal printer attached) and that
  // page auto-prints tickets as they arrive.
  kitchenPrintEnabled Boolean @default(false)
  barPrintEnabled     Boolean @default(false)
  printPaperWidthMm   Int     @default(80)

  // === Identidad legal + branding del comercio ============================
  //
  // Datos que aparecen en facturas, tirillas y al ser un comercio
  // formal. Todos opcionales por back-compat; cuando faltan, las
  // facturas simples no se pueden emitir (validamos a nivel de la
  // ruta de emisión).
  //
  // logoUrl — PNG o SVG subido vía /api/operator/uploads. Se muestra
  // en el menú del cliente, en facturas y donde la app necesite
  // identidad de marca. Cuando es null, todo cae al logo MESAPAY.
  logoUrl      String?
  legalName    String? // Razón social
  taxId        String? // NIT (solo dígitos; el DV se calcula al render)
  legalAddress String?
  legalCity    String?
  legalPhone   String?

  // Ubicación operativa del local (separada de los datos legales* de
  // facturación). Se captura al crear el restaurante, con autocompletado
  // de Google Places. Sirve para filtrar el portafolio por país/ciudad
  // (clave para la expansión multi-país CO/MX/BR/US). country guarda el
  // código ISO-3166-1 alpha-2 en mayúsculas (CO, MX, BR, US) para filtros
  // estables; countryName el nombre legible mostrado. address es la línea
  // formateada que devuelve Places.
  address     String?
  city        String?
  country     String? // ISO alpha-2 (CO, MX, …)
  countryName String? // nombre legible (Colombia, México, …)
  placeId     String? // Google Places place_id (referencia futura)

  // Resolución DIAN — texto descriptivo del acto administrativo
  // ("Resolución 18760000001 del 1 de enero de 2024"). El rango y
  // la fecha quedan como campos separados para mostrarlos en formato
  // estandard en la tirilla.
  dianResolution     String?
  dianResolutionFrom Int?
  dianResolutionTo   Int?
  dianResolutionDate DateTime?
  // Prefijo de los números (ej "POS", "FE"). Concatena con el
  // consecutivo al renderear.
  invoicePrefix      String?
  // Contador del próximo consecutivo a asignar. Incrementa
  // atómicamente cuando se emite una factura simple.
  invoiceNextNumber  Int       @default(1)

  // === Políticas del staff ================================================
  //
  // Configurables por el comercio desde /operator/settings/staff-policies.
  // No usamos enums Prisma para que agregar más policies en el futuro no
  // requiera migración. Helpers de validación + defaults viven en
  // src/lib/staffPolicies.ts.
  //
  // tipPolicy:
  //   "shared"    → las propinas son del restaurante (default histórico).
  //                 La vista "Yo" del mesero NO muestra propinas
  //                 acumuladas porque no son personales.
  //   "by_waiter" → cada propina queda atada al mesero que cobró
  //                 (Payment.collectedByUserId). La vista "Yo" suma
  //                 sus propinas por turno / día.
  //
  // shiftPolicy:
  //   "global"    → un solo Shift por restaurante, abierto/cerrado por
  //                 operador (flujo de arqueo existente). Shift.userId
  //                 queda null.
  //   "by_waiter" → cada mesero abre su propio Shift cuando entra a su
  //                 jornada. Coexiste con el shift global del restaurante
  //                 si lo hay; sirve para que el mesero tenga su propio
  //                 corte aunque la caja sea una sola.
  tipPolicy String @default("shared")

  // C2 (ERP staff) — asistencia estricta: turno pasado sin check-in =
  // falta ($0) en vez del estimado C1. Se enciende al adoptar el kiosko.
  staffStrictAttendance   Boolean @default(false)
  // C2 — recargo % sobre la hora ordinaria en festivos y domingos
  // (default 75/75, estándar CO; 0 = sin recargo).
  staffHolidayPct         Int     @default(75)
  staffSundayPct          Int     @default(75)
  // Divisor mensual para derivar el valor de la hora ordinaria del salario
  // básico (Colombia tradicional 240 = 30×8; MX análogo). Editable en los
  // ajustes de Horarios. valor hora = Employee.monthlySalaryCents / divisor.
  staffHoursDivisor       Int     @default(240)
  // Parámetros de liquidación de nómina (portado de zenith-erp): objeto
  // { key: number } en unidades humanas (pesos para valores, % para tasas).
  // null ⇒ defaults por país (CO 2026). El dueño los edita en Nómina.
  payrollParams           Json?
  // Compras: ¿el IVA de las facturas de compra es descontable? false
  // (default) ⇒ el IVA entra al costo de inventario (lo que se paga);
  // true ⇒ el costo de inventario es el neto y el IVA se registra aparte.
  purchaseIvaDeductible   Boolean @default(false)
  // Ventas: impuesto que aplica el restaurante sobre el subtotal (ERP A3).
  // "none" ⇒ no se discrimina impuesto (precio final); "inc" ⇒ Impuesto al
  // Consumo (impoconsumo, típico restaurantes CO); "iva" ⇒ IVA. El impuesto
  // se calcula EMBEBIDO en el precio del menú (no se suma encima): el
  // componente = subtotal × pct/(100+pct). Solo para reportes/contabilidad.
  salesTaxKind            String  @default("none") // none | inc | iva
  salesTaxPct             Int     @default(0) // p.ej. 8 (INC) o 19 (IVA)
  // Gastos de representación (ERP A3): permitir al mesero cerrar una cuenta
  // como cortesía ($0) sin cobrarla, con nota de a quién se le dio. El nombre
  // es configurable; null ⇒ etiqueta por defecto de i18n ("Gastos de
  // representación").
  compEnabled             Boolean @default(true)
  compLabel               String?
  // Categorías de insumos que NO manejan inventario: sus insumos se
  // excluyen del consumo automático al vender, del reorden y de la vista
  // de existencias. Los nombres coinciden con Ingredient.category.
  inventoryExcludedCategories String[] @default([])
  shiftPolicy             String  @default("global")
  // Hora de corte del día contable (hora Bogotá, 0–23). El día de
  // reportes/caja arranca a esta hora — para comercios que cierran de
  // madrugada (corte 5 = 05:00, así lo de 00:00–05:00 cuenta como el
  // día anterior). 0 = medianoche.
  businessDayCutoffHour   Int     @default(5)
  // Qué hacer si un mesero abre su turno sin que el local haya abierto el
  // general (solo by_waiter): "block" (no dejar) | "auto_open" (abrir el del
  // local con la misma base que declara el mesero). Ver staffPolicies.ts.
  meseroShiftWithoutLocal String  @default("block")

  users                  User[]
  tables                 Table[]
  menus                  Menu[]
  categories             Category[]
  menuItems              MenuItem[]
  orders                 Order[]
  dishRatings            DishRating[]
  membershipPayments     MembershipPayment[]
  billingSubscription    BillingSubscription?
  auditEvents            AuditEvent[]
  kushkiDocuments        KushkiDocument[]
  kushkiTransactions     KushkiTransaction[]
  walletMovements        WalletMovement[]
  payouts                Payout[]
  terminalDevices        TerminalDevice[]
  kushkiWebhookEvents    KushkiWebhookEvent[]
  invoiceRequests        InvoiceRequest[]
  simpleInvoices         SimpleInvoice[]
  shifts                 Shift[]
  cashMovements          CashMovement[]
  ingredients            Ingredient[]
  suppliers              Supplier[]
  stockLevels            StockLevel[]
  stockMovements         StockMovement[]
  stockCounts            StockCount[]
  purchaseOrders         PurchaseOrder[]
  recipes                Recipe[]
  expenses               Expense[]
  ledgerAccounts         LedgerAccount[]
  journalEntries         JournalEntry[]
  payrollRuns            PayrollRun[]
  productionBatches      ProductionBatch[]
  employees              Employee[]
  staffShifts            StaffShift[]
  dianConfig             DianConfig?
  dianDocuments          DianDocument[]
  purchaseInvoiceUploads PurchaseInvoiceUpload[]
  purchasePayments       PurchasePayment[]

  // Comercial asignado — el rep que trajo este restaurante y cobra comisión recurrente.
  salesRepUserId        String?
  salesRep              User?             @relation("RestaurantSalesRep", fields: [salesRepUserId], references: [id], onDelete: SetNull)
  salesRepCommissionBps Int?
  commissionEntries     CommissionEntry[]

  // CRM: leads asociados a este restaurante (cuando el lead se gana)
  crmLeads CrmLead[]

  @@index([slug])
  @@index([groupId])
  @@index([salesRepUserId])
}

/// Grupo de restaurantes — agrupa N locales bajo un mismo dueño/cadena.
/// Los miembros con role=group_admin ven todos los restaurantes del
/// grupo en /group, crean nuevos restaurantes, asignan razón social
/// compartida, y opcionalmente comparten menú. Los restaurantes que
/// no pertenecen a ningún grupo (la mayoría hoy) tienen groupId=null
/// y funcionan exactamente como antes — la feature es opt-in.
model Group {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurants   Restaurant[]
  members       User[]
  legalEntities LegalEntity[]

  @@index([slug])
}

/// Razón social del grupo. Un grupo puede tener N (caso: dueño con
/// varios NITs distintos para diferentes locales). Cada Restaurant
/// elige cuál usar via Restaurant.legalEntityId — y los locales
/// hermanos pueden compartir la misma numeración DIAN si están
/// bajo el mismo LegalEntity.
model LegalEntity {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name    String
  taxId   String
  address String?
  city    String?
  phone   String?

  // Resolución DIAN propia. Comparte numeración con todos los
  // restaurantes del grupo asignados a este LegalEntity.
  dianResolution     String?
  dianResolutionFrom Int?
  dianResolutionTo   Int?
  dianResolutionDate DateTime?
  invoicePrefix      String?
  invoiceNextNumber  Int       @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurants Restaurant[]
  dianConfig  DianConfig?

  @@index([groupId])
}

enum KushkiOnboardingStatus {
  not_started
  docs_uploaded
  submitted
  in_review
  active
  rejected
  suspended
}

enum Plan {
  trial
  basic
  pro
}

enum ServiceMode {
  table
  counter
}

enum MembershipMethod {
  manual_cash
  manual_transfer
  wompi
  kushki_card
}

/// Catálogo de planes editable desde /admin/plans. Una fila por
/// cada valor del enum `Plan`. La columna `tier` es la PK lógica
/// (unique) — el admin no puede crear/borrar tiers (eso requeriría
/// migrar el enum), pero sí editar nombre, descripción, precio
/// sugerido, features y visibilidad. La self-seed corre la primera
/// vez que se lee el catálogo (src/lib/planCatalog.ts).
model PlanConfig {
  id                String   @id @default(cuid())
  tier              Plan     @unique
  name              String
  description       String?
  defaultPriceCents Int      @default(0)
  // String[] de bullets; se serializa como Json para flexibilidad.
  features          Json     @default("[]")
  // Si false, no aparece como opción al elegir plan para un
  // restaurante nuevo. Los restaurantes existentes en ese plan
  // siguen funcionando.
  visible           Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Singleton de configuración global de la plataforma. Hoy sólo tiene
/// el modo Kushki (mock/sandbox/production) editable desde admin sin
/// necesidad de redeploy, pero está pensado para crecer (otros
/// toggles plataforma-wide). La fila usa id="singleton" como pk.
model PlatformConfig {
  id                         String   @id @default("singleton")
  /// "mock" | "sandbox" | "production". Usamos String en vez de enum
  /// para permitir modos futuros sin schema migration. Si el valor
  /// no matchea ninguno conocido, el helper cae a env.KUSHKI_MODE.
  kushkiMode                 String   @default("mock")
  updatedAt                  DateTime @updatedAt
  updatedById                String?
  // Default global de mensajes/día del asistente Pulso (override por comercio
  // en Restaurant.aiDailyMessageLimit).
  aiDailyMessageLimit        Int      @default(50)
  // Default global de comisión en basis points; override por comercial y por comercio.
  salesCommissionBps         Int      @default(1000)
  // Credenciales Kushki de plataforma para cobro de suscripciones a restaurantes.
  // La clave pública es segura (se pasa al browser para tokenizar tarjetas).
  // La clave privada se almacena cifrada con AES-GCM (ver src/lib/crypto.ts).
  // Fallback: si están vacías, se leen de env KUSHKI_BILLING_PUBLIC_KEY / KUSHKI_BILLING_PRIVATE_KEY.
  kushkiBillingPublicKey     String?
  kushkiBillingPrivateKeyEnc String?
}

/// Audit log de acciones administrativas. Lo escriben los endpoints
/// que mutan estado sensible — cambio de plan, suspensión, registro
/// de pago manual, edición del catálogo de planes, edición de
/// identidad/pagos del comercio, creación/borrado de usuarios, etc.
///
/// `restaurantId` es null cuando el evento es a nivel plataforma
/// (ej: editar el catálogo de planes — no pertenece a un comercio).
/// `targetType` + `targetId` permiten linkear de vuelta al objeto
/// afectado para que la UI pueda hacer "ver detalle" si quiere.
/// `summary` es human-readable y siempre se llena (lo que se
/// renderea en la lista). `diff` opcional guarda before/after para
/// inspección detallada.
model AuditEvent {
  id           String      @id @default(cuid())
  occurredAt   DateTime    @default(now())
  // Quién hizo el cambio. userId puede ser null si la acción fue
  // disparada por un cron del sistema; email se denormaliza para
  // que el historial siga siendo legible aunque el usuario se borre
  // después.
  actorUserId  String?
  actorEmail   String
  actorRole    String
  // Scope: comercio afectado o null para acciones a nivel plataforma.
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  // Qué se cambió. kind es un slug estable (ej: "plan.update",
  // "membership.payment", "restaurant.suspend") para filtrar.
  kind         String
  targetType   String?
  targetId     String?
  // Texto listo para mostrar en la lista — "Cambió plan a Pro y
  // mensualidad a $400.000". El renderer no necesita interpretar.
  summary      String
  // Opcional: snapshot del estado antes/después para inspección.
  diff         Json?

  @@index([restaurantId, occurredAt])
  @@index([kind, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([occurredAt])
}

model MembershipPayment {
  id              String           @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  amountCents     Int
  method          MembershipMethod
  note            String?
  periodStart     DateTime
  periodEnd       DateTime
  recordedByEmail String
  createdAt       DateTime         @default(now())
  providerRef     String? // id de transacción Kushki (null en pagos manuales)
  kind            String           @default("manual") // "initial" | "recurring" | "proration" | "manual"

  commissionEntry CommissionEntry?

  @@index([restaurantId, createdAt])
}

/// Suscripción de débito automático del restaurante (1 por comercio).
/// Vincula al comercio con Kushki (One-click & scheduled payments) y
/// guarda SOLO metadata de tarjeta para mostrar — nunca el PAN. La
/// fuente de verdad del plan sigue en Restaurant (plan/monthlyPriceCents/
/// periodEndsAt/suspended); este modelo agrega el medio de pago + estado
/// de cobro recurrente. Ver docs/superpowers/specs/2026-06-19-operator-subscription-billing-design.md
model BillingSubscription {
  id                   String     @id @default(cuid())
  restaurantId         String     @unique
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  provider             String     @default("kushki")
  kushkiSubscriptionId String?
  plan                 Plan
  amountCents          Int
  currency             String // "COP" | "MXN"
  status               String     @default("active") // "active" | "past_due" | "canceled"
  cardBrand            String?
  cardLast4            String?
  cardExpMonth         Int?
  cardExpYear          Int?
  startedAt            DateTime   @default(now())
  currentPeriodEnd     DateTime?
  nextChargeAt         DateTime?
  failedAttempts       Int        @default(0)
  canceledAt           DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([status, nextChargeAt])
}

model CommissionEntry {
  id                  String            @id @default(cuid())
  salesRepUserId      String
  salesRep            User              @relation(fields: [salesRepUserId], references: [id], onDelete: Cascade)
  restaurantId        String
  restaurant          Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  membershipPaymentId String            @unique
  membershipPayment   MembershipPayment @relation(fields: [membershipPaymentId], references: [id], onDelete: Cascade)
  baseAmountCents     Int
  bps                 Int
  amountCents         Int
  status              CommissionStatus  @default(pending)
  createdAt           DateTime          @default(now())
  paidAt              DateTime?
  paidNote            String?

  @@index([salesRepUserId, createdAt])
  @@index([restaurantId])
  @@index([status])
}

enum Role {
  customer
  operator
  platform_admin
  // Smart POS device on a Kushki terminal — exists since the cloud-push
  // datafono flow.
  terminal
  // Mobile-first staff role with a bottom nav (Salón / Cobros / Mesas)
  // optimised for PWA install + push notifications.
  mesero
  // Single-purpose roles that land the user on their station board with
  // no top nav — they don't need to navigate around the app.
  kitchen
  bar
  // Group admin — gestiona varios restaurantes desde /group. Puede
  // crear restaurantes nuevos bajo el grupo, configurar razones
  // sociales compartidas, e impersonar como operator de cualquier
  // restaurante del grupo. Scoped al grupo: NO ve restaurantes
  // ajenos. Distinto a platform_admin (que ve todo MESAPAY).
  group_admin
  // Sales rep que trae restaurantes y cobra comisión recurrente;
  // su portal es /comercial.
  comercial
  // Gerente de equipo comercial: ve y gestiona los comerciales con
  // managerId=él y sus leads; además opera su propio pipeline como
  // un comercial normal. Jerarquía de exactamente 2 niveles.
  gerente_comercial
}

enum CommissionStatus {
  pending
  paid
  reversed
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  name           String?
  phone          String?
  passwordHash   String
  role           Role        @default(customer)
  restaurantId   String?
  restaurant     Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  // Mutuamente excluyente con restaurantId. Para users con
  // role=group_admin guardamos el grupo al que pertenecen — desde
  // ahí pueden impersonar cualquiera de sus restaurantes.
  groupId        String?
  group          Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  marketingOptIn Boolean     @default(false)
  welcomedAt     DateTime?
  createdAt      DateTime    @default(now())

  orders Order[] @relation("OrderCustomer")

  uploadedKushkiDocuments KushkiDocument[] @relation("KushkiDocumentUploader")
  terminalDevices         TerminalDevice[]

  // For `mesero` users: the table numbers this person is responsible
  // for in the dining room. Empty array = sees every table (back-
  // compat default + the "el mesero atiende todo" case). Populated =
  // mesero only sees those numbers in Salón / Cobros / Mesas — useful
  // for restaurants with many tables where each mesero has a section.
  // Operators / platform_admin / kitchen / bar / terminal ignore this
  // field; only the mesero role is filtered.
  assignedTableNumbers Int[] @default([])

  shiftsOpened  Shift[]        @relation("ShiftsOpened")
  shiftsClosed  Shift[]        @relation("ShiftsClosed")
  cashMovements CashMovement[] @relation("CashMovementCreator")
  // Shifts donde este user es el dueño (modo by_waiter). Distinto a
  // shiftsOpened/Closed que pueden referenciar al operador que
  // abrió/cerró un turno de OTRO mesero (admin operativo).
  shiftsOfUser  Shift[]        @relation("ShiftsOfUser")

  // Pagos físicamente cobrados por este user (mesero/operator). Útil
  // para vista "Yo": sum(tipCents) + count(payments) por turno.
  paymentsCollected Payment[] @relation("PaymentsCollected")

  pushSubscriptions PushSubscription[]

  // ERP: movimientos de inventario / conteos creados por este usuario.
  stockMovements           StockMovement[]         @relation("StockMovementCreator")
  expensesCreated          Expense[]               @relation("ExpenseCreator")
  productionBatchesCreated ProductionBatch[]       @relation("ProductionBatchCreator")
  purchaseInvoiceUploads   PurchaseInvoiceUpload[]
  purchasePayments         PurchasePayment[]       @relation("PurchasePaymentCreator")
  employeeProfile          Employee?
  stockCounts              StockCount[]            @relation("StockCountCreator")
  purchaseOrders           PurchaseOrder[]         @relation("PurchaseOrderCreator")

  // Comisiones comerciales
  commissionBps       Int?
  referredRestaurants Restaurant[]      @relation("RestaurantSalesRep")
  commissionEntries   CommissionEntry[]

  /// usuario desactivado: no puede iniciar sesión; un comercial desactivado
  /// tampoco acumula comisiones nuevas. null = activo.
  disabledAt DateTime?

  // CRM: código ISO-2 del país del comercial. Cuando está presente, el
  // campo país del lead queda bloqueado a este valor al crear.
  countryCode String?
  // CRM: gerente_comercial asignado a este comercial. Null = sin gerente
  // (o es él mismo el gerente). Relación self "SalesTeam".
  managerId   String?
  manager     User?   @relation("SalesTeam", fields: [managerId], references: [id], onDelete: SetNull)
  team        User[]  @relation("SalesTeam")

  // CRM inverse relations
  assignedCrmLeads     CrmLead[]             @relation("CrmAssigned")
  createdCrmLeads      CrmLead[]             @relation("CrmCreated")
  crmActivities        CrmActivity[]
  crmAppointments      CrmAppointment[]
  crmEmailAccount      CrmEmailAccount?
  crmDocuments         CrmDocument[]
  crmEmailTemplates    CrmEmailTemplate[]
  crmWhatsappTemplates CrmWhatsappTemplate[]
  passwordResetTokens  PasswordResetToken[]

  @@index([restaurantId])
  @@index([groupId])
  @@index([managerId])
}

/// Token de restablecimiento de contraseña (disparado desde admin).
/// Se guarda el SHA-256 del token — el token plano solo viaja en el link
/// del correo. Un solo uso (usedAt) y vence en 1 hora (expiresAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Web Push subscription registered by a mesero (or any staff) from
// their PWA. Holds the endpoint + crypto keys we need to send a push
// via the VAPID protocol. One user can have multiple subscriptions
// (different devices). On 410 Gone from the push service we delete
// the row — subscriptions expire on the user's end too.
model PushSubscription {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Denormalised so push sender helpers don't have to join through
  // user to filter by restaurant. Set on create.
  restaurantId String?
  endpoint     String    @unique
  p256dh       String
  auth         String
  userAgent    String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
  @@index([restaurantId])
}

model Table {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  number       Int
  label        String?
  qrToken      String     @unique
  createdAt    DateTime   @default(now())

  // Llamadas al mesero PRE-orden — cuando un cliente escanea el QR
  // y aprieta "Llamar mesero" sin haber pedido nada todavía no hay
  // Order donde colgar la flag. Persistimos a nivel de Table para
  // que el Salón los surface igual.
  //
  // Pending = waiterCalledAt != null && (waiterAckedAt == null ||
  // waiterAckedAt < waiterCalledAt). Cuando el mesero hace ack se
  // setea waiterAckedAt = now, sin borrar waiterCalledAt — así el
  // historial queda y un re-call del cliente vuelve a marcar pending.
  waiterCalledAt DateTime?
  waiterAckedAt  DateTime?

  // ─── Reservas ───────────────────────────────────────────────────
  // Atributos por mesa que usa el módulo de reservas. Todos
  // opcionales con defaults sensatos para que las mesas existentes
  // (creadas antes del feature) no se rompan ni queden inconsistentes.
  //
  // capacity: cantidad de comensales que entran. Default 4 — operador
  // ajusta por mesa desde /operator/settings/mesas.
  // minConsumptionCents: consumo mínimo informativo que se muestra
  // al diner al reservar y al imprimir la cuenta. null = sin mínimo.
  // shape: cómo se renderiza en el floor plan. Bar es horizontal.
  // reservable: si la mesa acepta reservas (algunas son walk-in only).
  // floorPlanX/Y: coords en la grilla del editor visual (Fase 4).
  // null/null = mesa todavía no posicionada.
  capacity                Int        @default(4)
  minConsumptionCents     Int?
  shape                   TableShape @default(square)
  reservable              Boolean    @default(true)
  floorPlanX              Int?
  floorPlanY              Int?
  // Depósito para reservar esta mesa. null/0 = sin depósito. Se cobra
  // online al reservar (tarjeta/PSE) y se abona a la cuenta al llegar
  // (no reembolsable si no se presentan). Lo edita el operador en
  // /operator/settings/mesas.
  reservationDepositCents Int?

  orders       Order[]
  reservations Reservation[]

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([restaurantId, waiterCalledAt])
}

enum TableShape {
  square
  round
  bar
}

// Reservas: el diner aparta una mesa para un slot (definido por la
// config del restaurante: turnos × duración). Una reserva tiene un
// confirmationCode único — sirve para que el diner cancele/modifique
// sin necesidad de login. El operador maneja el ciclo de vida desde
// /operator/reservas.
//
// startsAt/endsAt absolutos en UTC; el slot exacto se reconstruye al
// renderizar con la zona horaria del restaurante.
model Reservation {
  id               String            @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId          String
  table            Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)
  customerName     String
  customerEmail    String
  customerPhone    String?
  partySize        Int
  startsAt         DateTime
  endsAt           DateTime
  status           ReservationStatus @default(pending)
  source           ReservationSource @default(direct)
  notes            String?
  // Se le manda al diner por email — link a la página de cancelación.
  // Mínimo 12 chars random para evitar enumeración.
  confirmationCode String            @unique
  // Lo setea el webhook que confirma / cancela / marca no-show. Mantenido
  // como JSON liviano para que un operador pueda escribir notas internas
  // sin migración (ej. "llamó por teléfono, pidió mesa cerca de ventana").
  internalLog      Json?

  // ─── Depósito / abono ───────────────────────────────────────────
  // depositCents: monto del depósito snapshotteado al reservar (de
  //   Table.reservationDepositCents). null/0 = no exige depósito.
  // depositStatus: ver enum DepositStatus.
  // depositMethod: con qué se pagó el depósito (kushki_card / kushki_pse…).
  // depositTxId: providerRef de Kushki (para conciliación / refund futuro).
  // holdExpiresAt: mientras está pending, la reserva aparta la mesa sólo
  //   hasta este instante; si vence sin pagar, deja de bloquear el slot.
  // appliedOrderId: orden a la que se acreditó el abono (status=applied).
  // depositPaymentId: el Payment-crédito que se creó al acreditar.
  depositCents     Int?
  depositStatus    DepositStatus  @default(none)
  depositMethod    PaymentMethod?
  depositTxId      String?
  holdExpiresAt    DateTime?
  appliedOrderId   String?
  depositPaymentId String?

  // Idioma del comensal al reservar (cookie MESAPAY_LOCALE). El email de
  // confirmación se manda en este idioma aunque lo dispare un webhook de
  // depósito (sin cookie). null ⇒ default (es). i18n fase 4.
  locale String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, startsAt])
  @@index([tableId, startsAt])
  @@index([confirmationCode])
}

enum ReservationStatus {
  pending // nueva, esperando confirmación si auto-confirm = false
  confirmed // confirmada (auto o manual por operador)
  seated // el grupo llegó y se sentó
  completed // terminaron y se fueron
  cancelled // diner u operador la canceló antes
  no_show // no se presentaron
}

enum ReservationSource {
  direct // sitio nuestro (link directo)
  google_maps // deep link desde Google Business Profile
  whatsapp // WA Business (futuro)
  phone // operador la cargó manualmente
}

enum CategoryKind {
  starter
  main
  side
  drink
  dessert
  other
}

// Where this item is prepared. Drives which board ticket lands on, and
// whether the item needs preparation at all.
//   kitchen  → normal cocina flow
//   bar      → bartender board (if hasBar=true), else falls through to
//              the waiter view like a counter item
//   counter  → self-serve / refri / pickup from the bar shelf — auto
//              marked ready at send time, no prep stage
enum PrepStation {
  kitchen
  bar
  counter
}

// A "menu" is a top-level grouping of categories — the diner-facing
// equivalent of a physical menu book. Most restaurants only need one
// (the "Carta"), but places with extensive wine lists or separate
// cocktail / brunch menus benefit from splitting them up so 200
// wines don't bury the pasta section. Each restaurant always has a
// default "Carta" menu; additional ones are opt-in.
model Menu {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  slug         String
  label        String
  description  String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  categories Category[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
}

model Category {
  id            String       @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  // Which menu this category belongs to. Optional because of the
  // backfill window: existing data starts with null and a server-side
  // ensureDefaultMenu() helper assigns it to the restaurant's "Carta"
  // menu the next time anyone reads the menu. Treat null in the UI as
  // "default menu" so we don't break in flight.
  menuId        String?
  menu          Menu?        @relation(fields: [menuId], references: [id], onDelete: SetNull)
  slug          String
  label         String
  sortOrder     Int          @default(0)
  kind          CategoryKind @default(other)
  // Default station for items in this category. Items can override
  // individually via MenuItem.prepStation.
  prepStation   PrepStation  @default(kitchen)
  // Only meaningful when prepStation=bar AND the restaurant has
  // sub-stations defined. Free-text label that should match one of
  // Restaurant.barSubStations. Null means "no specific sub-station" —
  // shows on the default tab of /operator/bar.
  barSubStation String?

  // Subcategorías (un solo nivel). Una categoría puede colgar de otra
  // ("Malbec" dentro de "Vino Tinto"). La regla de un solo nivel se valida en
  // la API (un padre no puede tener padre). Al borrar el padre, los hijos
  // quedan en el nivel superior (parentId → null), no se borran.
  parentId String?
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryChildren")

  items MenuItem[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
  @@index([menuId])
  @@index([parentId])
}

model MenuItem {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name        String
  description String?
  priceCents  Int
  tags        String[]
  photoUrl    String?
  modifiers   Json?
  recipe      Recipe? // ERP A3 — receta del plato (costeo + consumo A4)
  available   Boolean      @default(true)
  sortOrder   Int          @default(0)
  // Float: permite tiempos con decimales (ej. 1.5 min para bebidas).
  prepMinutes Float        @default(10)
  // Override the category's default prep station for this specific item.
  // null = inherit from category.prepStation. Common case: "Bebidas" =
  // bar but "Jugo natural" overrides to kitchen because it requires prep.
  prepStation PrepStation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  ratings    DishRating[]

  @@index([restaurantId, categoryId])
}

enum OrderStatus {
  open
  placed
  in_kitchen
  ready
  served
  paying
  paid
  cancelled
}

enum KitchenState {
  placed
  in_kitchen
  ready
}

enum ServingMode {
  asReady
  together
}

enum OrderType {
  dineIn
  pickup
}

model Order {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String
  table        Table      @relation(fields: [tableId], references: [id])
  customerId   String?
  customer     User?      @relation("OrderCustomer", fields: [customerId], references: [id])

  status    OrderStatus @default(open)
  shortCode String      @unique
  diners    Int         @default(1)
  notes     String?

  // Idioma del comensal al crear la orden (cookie MESAPAY_LOCALE). Permite
  // mandar la factura/bienvenida en su idioma incluso cuando el email lo
  // dispara el operador (cobro en caja/datáfono) o un webhook futuro, donde
  // no hay cookie del comensal. null ⇒ default (es). i18n fase 4.
  locale String?

  subtotalCents Int @default(0)
  tipCents      Int @default(0)
  taxCents      Int @default(0)
  totalCents    Int @default(0)

  servingMode ServingMode @default(asReady)

  orderType   OrderType @default(dineIn)
  etaMinutes  Int?
  readyEta    DateTime?
  pickupName  String?
  pickupPhone String?

  // Correo del titular capturado al pagar con tarjeta (CardSheet). Sirve para
  // prellenar el pedido de factura en /done y no volver a pedirlo. Nullable:
  // efectivo/Apple Pay pueden no traerlo. El último cobro con correo gana.
  customerEmail String?

  needsWaiter    Boolean   @default(false)
  waiterCalledAt DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  placedAt        DateTime?
  servedAt        DateTime?
  paidAt          DateTime?
  // Cuenta cerrada como cortesía / gastos de representación (ERP A3): sin
  // cobro. Los ítems quedan comp (consumen inventario, no venden) y la orden
  // se cierra en $0. compAmountCents = valor de venta regalado (auditoría/
  // reporte); compNote = a quién se le dio; compLabel = etiqueta usada.
  compedAt        DateTime?
  compNote        String?
  compLabel       String?
  compAmountCents Int?
  // A4 — marca idempotente del consumo automático de inventario: se
  // reclama con updateMany({ stockConsumedAt: null }) en la misma tx que
  // los movimientos. Set también cuando no hay nada que consumir
  // (módulos apagados / sin recetas) para que el cron no re-visite.
  stockConsumedAt DateTime?

  items           OrderItem[]
  payments        Payment[]
  rounds          Round[]
  ratings         DishRating[]
  invoiceRequests InvoiceRequest[]
  simpleInvoice   SimpleInvoice?
  stockMovements  StockMovement[]

  @@index([restaurantId, status])
  @@index([tableId])
  @@index([restaurantId, needsWaiter])
}

model Round {
  id                       String      @id @default(cuid())
  orderId                  String
  order                    Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seq                      Int
  status                   OrderStatus @default(placed)
  placedAt                 DateTime    @default(now())
  kitchenStartedAt         DateTime?
  readyAt                  DateTime?
  // Cancelled rounds are pulled out of the kitchen board immediately. We
  // keep them in the DB for the audit trail — cancelledBy/At pair plus the
  // free-text reason captured at the moment of cancellation.
  cancelledAt              DateTime?
  cancelledByEmail         String?
  cancellationReason       String?
  // The waiter clicks "avisé al cliente" once they've gone to the table.
  // Until then the cancellation surfaces in Salón as an action item.
  cancellationAckedAt      DateTime?
  cancellationAckedByEmail String?

  items OrderItem[]

  @@unique([orderId, seq])
  @@index([orderId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  roundId    String?
  round      Round?   @relation(fields: [roundId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  qty                  Int          @default(1)
  nameSnapshot         String
  priceCentsSnapshot   Int
  modifierSelections   Json?
  notes                String?
  guestName            String?
  kitchenStatus        KitchenState @default(placed)
  categoryKind         CategoryKind @default(other)
  // Snapshot of the resolved station at send time. We freeze it on the
  // ticket so re-routing the menu later doesn't yank already-fired items
  // between boards mid-service.
  station              PrepStation  @default(kitchen)
  // Same snapshot logic for the bar sub-station. Null when not a bar
  // item or when the restaurant has no sub-stations configured.
  barSubStation        String?
  // Snapshot of prepMinutes at send time. Used by the bar board for the
  // countdown timer; the kitchen board ignores this and lets the cook
  // mark ready manually. We snapshot (vs. reading from MenuItem live)
  // because editing the menu mid-service shouldn't shift the timer on
  // tickets that are already on the board.
  prepMinutesSnapshot  Float        @default(10)
  // When the item moved placed → in_kitchen. Drives the bar countdown
  // (remaining = prepMinutesSnapshot - (now - preparationStartedAt)).
  // Survives page reloads so the countdown picks up where it left off.
  preparationStartedAt DateTime?
  servedAt             DateTime?

  // "Apurar" — el mesero / operador marca un plato como urgente
  // desde la vista de mesa cuando el cliente pregunta dónde está
  // su comida. Se refleja en el kitchen board como badge 🔥 +
  // ordena el item arriba en su round. Null = no apurado (default).
  expediteRequestedAt      DateTime?
  expediteRequestedByEmail String?

  // Cancelación a nivel item — distinto a Round.cancelledAt que
  // tumba la ronda completa. Cuando el cliente dice "saca el lomito
  // pero deja los demás", el mesero usa esto desde el detail sheet.
  // Items con cancelledAt != null se excluyen del subtotal, del
  // kitchen/bar board, del Salón y del breakdown del cobro. El
  // motivo es free-text (con presets en la UI). El email es para
  // auditoría — quién canceló.
  //
  // `cancellationKind` distingue el caso semántico:
  //   "cancel" — cocina no llegó a tocar el plato (o se va a tirar,
  //              poco común). Sin cobro porque nunca se entregó.
  //   "comp"   — cocina lo hizo, se sirvió, pero no se cobra:
  //              queja del cliente (frío, mal preparado, no le gustó),
  //              cortesía, o walkout (se fue sin pagar).
  // La diferencia importa para el reporte admin — un comp consume
  // ingredientes/tiempo de cocina, un cancel no. Filas viejas con
  // cancellationKind=null se tratan como "cancel" por back-compat.
  cancelledAt        DateTime?
  cancellationReason String?
  cancelledByEmail   String?
  cancellationKind   String?

  rating DishRating?

  @@index([orderId])
  @@index([roundId])
}

model DishRating {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId  String     @unique
  orderItem    OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  stars        Int
  comment      String?
  guestName    String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([menuItemId])
}

enum PaymentMethod {
  demo_card
  demo_cash
  wompi_card
  wompi_pse
  wompi_nequi
  // Kushki live methods. demo_* remain for local development and historical
  // rows. kushki_card_terminal is the cloud-pushed Smart POS flow; the
  // Apple/Google methods are wallet-tokenised charges from the JS SDK.
  kushki_apple_pay
  kushki_google_pay
  kushki_card_terminal
  // Datáfono propio del comercio (Bancolombia, Davivienda, etc.) — el
  // mesero acerca su POS físico externo y cobra ahí. MESAPAY sólo
  // registra que el cobro ocurrió (settlement manual desde Salón).
  // Útil para comercios que aún no migran a Kushki o que tienen un
  // contrato de adquiriente preexistente que prefieren mantener.
  external_terminal
  // PSE (Pagos Seguros en Línea) vía Kushki — el cliente se va a la
  // web de su banco, autentica, hace la transferencia, y vuelve.
  // Asíncrono: el resultado final llega por webhook.
  kushki_pse
  // Tarjeta de crédito/débito ingresada en MESAPAY directamente. El
  // browser tokeniza con Kushki.js (datos NO pasan por nuestro server,
  // PCI scope queda en SAQ-A) y el backend hace el charge usando la
  // private key del sub-merchant. Sincrónico: respuesta approved/declined
  // viene en la misma llamada.
  kushki_card
  // Abono de reserva: el cliente pagó un depósito al reservar (vía
  // Kushki) y al sentarse se acredita a la cuenta como un pago ya
  // recibido. No es un cobro nuevo en la mesa — es plata que ya entró.
  reservation_deposit
}

/**
 * Estado del depósito de una reserva.
 * none      — la mesa no exige depósito.
 * pending   — reserva creada, esperando el pago del depósito (hold).
 * paid      — depósito cobrado OK; la reserva queda confirmada.
 * applied   — el abono ya se acreditó a la cuenta cuando llegaron.
 * forfeited — no se presentaron (no-show): el comercio lo retiene.
 * refunded  — se devolvió (futuro / casos manuales).
 */
enum DepositStatus {
  none
  pending
  paid
  applied
  forfeited
  refunded
}

enum PaymentStatus {
  pending
  approved
  declined
  refunded
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  status          PaymentStatus @default(pending)
  amountCents     Int
  tipCents        Int           @default(0)
  splitOfCount    Int?
  providerRef     String?
  // Only set for cash payments where the diner declared upfront with how
  // much they'd pay (e.g. "voy a pagar con $100k"). Lets the waiter bring
  // exact change on the first trip. Operator can overwrite at settle time
  // if the diner changes their mind.
  cashTenderCents Int?
  createdAt       DateTime      @default(now())
  settledAt       DateTime?

  // Devoluciones (solo Kushki tarjeta). refundedCents acumula lo reintegrado;
  // cuando alcanza amountCents el pago pasa a status=refunded. El neto cobrado
  // resta refundedCents. Cada devolución queda además en KushkiTransaction
  // (kind=refund) con su detalle. Aditivo/nullable → prisma db push seguro.
  refundedCents Int       @default(0)
  refundedAt    DateTime?

  // Set when this payment is rolled into a shift close (arqueo de caja).
  // Stays null while the shift is open or if there was no open shift.
  shiftId String?
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  // Quién cobró físicamente este pago. Lo escribimos siempre que el
  // staff (mesero / operator / platform_admin) settle desde un endpoint
  // — independiente de la tipPolicy del restaurante, los datos son
  // útiles aun cuando la propina sea compartida (auditoría, vista
  // personal por mesero). Null = pago iniciado por el cliente desde
  // su propio QR.
  collectedByUserId String?
  collectedBy       User?   @relation("PaymentsCollected", fields: [collectedByUserId], references: [id])

  kushkiTransactions KushkiTransaction[]

  @@index([orderId])
  @@index([shiftId])
  @@index([collectedByUserId])
}

// === Cierre de turno ======================================================
//
// One Shift per restaurant from "abrir turno" (operator declares opening
// cash float) to "cerrar turno" (operator declares the physical cash they
// counted; system computes the difference vs what payments say should be
// there). Approved payments get pinned to the shift at close time so a
// historical close stays consistent even if a payment is edited later.

enum ShiftStatus {
  open
  closed
}

model Shift {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  status ShiftStatus @default(open)

  // Cuando shiftPolicy = "by_waiter", cada mesero tiene su propio
  // Shift y este campo apunta a él. Null = turno global del
  // restaurante (default histórico) — abierto/cerrado por operador
  // y agregando todas las ventas del local. Los dos modos coexisten
  // sin chocar: queries filtran por userId is null / not null según
  // contexto.
  userId String?
  user   User?   @relation("ShiftsOfUser", fields: [userId], references: [id])

  openedAt         DateTime @default(now())
  openedById       String
  openedBy         User     @relation("ShiftsOpened", fields: [openedById], references: [id])
  // Fondo de caja inicial — efectivo con el que arrancó el turno para dar
  // vueltas. Suma al efectivo esperado al cerrar.
  openingCashCents Int

  // Solo en el turno GENERAL (userId null): true si lo abrió automáticamente
  // un mesero (meseroShiftWithoutLocal="auto_open") en vez del operador. En
  // ese caso el local no tiene fondo central propio: el fondo es la suma de
  // las bases que traen los meseros, así que cada apertura de mesero SUMA su
  // base a openingCashCents (en vez de descontarla del cajón). Ver
  // src/app/api/mesero/shift/open/route.ts.
  autoOpened Boolean @default(false)

  closedAt          DateTime?
  closedById        String?
  closedBy          User?     @relation("ShiftsClosed", fields: [closedById], references: [id])
  // Efectivo físico que el cajero declaró al cerrar.
  declaredCashCents Int?
  // Lo que el sistema esperaba según pagos en efectivo + fondo inicial.
  expectedCashCents Int?
  // declared - expected. Positivo = sobrante, negativo = faltante.
  cashDiffCents     Int?
  notes             String?

  payments      Payment[]
  cashMovements CashMovement[]

  @@index([restaurantId, status])
  @@index([restaurantId, openedAt])
  @@index([userId, status])
}

enum CashMovementKind {
  egreso // sale efectivo del cajón del local (retiro con concepto)
  ingreso // entra efectivo (ajuste / depósito) para cuadrar
}

/**
 * Movimiento manual de efectivo de la caja general del local — egresos
 * (retiros con concepto) e ingresos (ajustes). Lo registra el operador
 * o el admin. El saldo de la caja NO se persiste: se calcula en vivo
 * (ver src/lib/cashBox.ts) a partir de base + cobros − egresos + ingresos.
 */
model CashMovement {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  // Turno global vigente al registrar (acota el movimiento al arqueo de
  // ese cierre). Null si no había turno global abierto.
  shiftId      String?
  shift        Shift?           @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  kind         CashMovementKind
  amountCents  Int // siempre > 0; el signo lo da el kind
  concept      String
  createdById  String
  createdBy    User             @relation("CashMovementCreator", fields: [createdById], references: [id])
  occurredAt   DateTime         @default(now())

  @@index([restaurantId, occurredAt])
  @@index([shiftId])
}

// === ERP · Fase A0: fundaciones (insumos, unidades, proveedores) ==========
// Spec: docs/superpowers/specs/2026-07-03-erp-a0-fundaciones-design.md
// Cantidades SIEMPRE en unidad base (mass→g, volume→ml, count→un) como Int.
// Conversiones y formateo en src/lib/erp/units.ts. Los empaques de compra
// ("caja × 24", "bulto 50 kg") son presentaciones del proveedor
// (SupplierIngredient.contentQty en unidad base), no unidades.

enum MeasureKind {
  mass // base: gramo
  volume // base: mililitro
  count // base: unidad
}

/// Insumo / materia prima del comercio. Base de inventario (A1),
/// compras (A2) y recetas (A3). Soft-delete vía active — las fases
/// siguientes referencian estas filas desde movimientos/recetas/OCs.
model Ingredient {
  id               String      @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name             String
  // Categoría libre ("Proteínas", "Lácteos", "Empaques"…) — sin taxonomía
  // impuesta; la UI sugiere las existentes del comercio con un datalist.
  category         String?
  measureKind      MeasureKind
  sku              String?
  notes            String?
  active           Boolean     @default(true)
  // A4 — punto de reorden en unidad base (null = sin aviso) y cantidad
  // sugerida de compra (null = pedir hasta cubrir el punto).
  reorderPointBase Int?
  reorderQtyBase   Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  supplierItems      SupplierIngredient[]
  stockLevel         StockLevel?
  stockMovements     StockMovement[]
  stockCountItems    StockCountItem[]
  purchaseOrderItems PurchaseOrderItem[]
  recipe              Recipe?              @relation("IngredientRecipe")
  recipeItems         RecipeItem[]
  modifierRecipeItems ModifierRecipeItem[]
  productionBatches   ProductionBatch[]    @relation("BatchOutput")

  @@unique([restaurantId, name])
  @@index([restaurantId, active])
}

/// Proveedor del comercio.
model Supplier {
  id               String     @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name             String
  taxId            String? // NIT / RFC
  contactName      String?
  phone            String? // E.164 (normalizePhone del CRM)
  email            String?
  address          String?
  paymentTermsDays Int? // condiciones de pago en días; null = contado
  notes            String?
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  items          SupplierIngredient[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]

  @@unique([restaurantId, name])
  @@index([restaurantId, active])
}

/// Lista de precios: qué insumos vende cada proveedor, en qué
/// presentación y a qué precio.
model SupplierIngredient {
  id           String     @id @default(cuid())
  supplierId   String
  supplier     Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  // Presentación de compra: "Caja × 24", "Bulto 50 kg", "Garrafa 20 L".
  presentationLabel String
  // Contenido de UNA presentación en unidad base del insumo (g/ml/un).
  contentQty        Int
  // Último precio por presentación, en centavos. Manual en A0; la
  // recepción de OCs (A2) lo actualizará automáticamente.
  lastPriceCents    Int?
  supplierSku       String?
  // Proveedor habitual del insumo — lo usa la OC sugerida (A4). Máx. 1
  // por insumo (la API desmarca el anterior al marcar uno nuevo).
  preferred         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poItems      PurchaseOrderItem[]
  priceHistory SupplierPriceHistory[]

  @@unique([supplierId, ingredientId])
  @@index([ingredientId])
}

// === ERP · Fase A1: inventario core =======================================
// Spec: docs/superpowers/specs/2026-07-03-erp-a1-inventario-design.md
// Libro inmutable (StockMovement, append-only) + saldo materializado
// (StockLevel, actualizado en la MISMA tx). Costo promedio ponderado con
// enteros exactos: qtyBase + totalValueCents, promedio = derivado. El stock
// puede quedar negativo (el inventario nunca bloquea la operación). Único
// camino de escritura: applyStockMovement en src/lib/erp/stock.ts.

enum StockMovementKind {
  purchase_in // entrada de mercancía (manual en A1; recepción de OC en A2)
  adjust_in // ajuste manual +
  adjust_out // ajuste manual −
  count_adjust // diferencia de conteo físico (±)
  waste // merma (−) con motivo
  sale_consumption // A4 — consumo automático por venta
  transfer_in // A5
  transfer_out // A5
  production_in // A5
  production_out // A5
}

enum WasteReason {
  expired
  damaged
  kitchen_error
  spill
  other
}

/// Saldo materializado por insumo (1:1 con Ingredient). Costo promedio =
/// totalValueCents / qtyBase (derivado, nunca persistido).
model StockLevel {
  id              String     @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  ingredientId    String     @unique
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qtyBase         Int        @default(0) // puede ser negativo (señal de conteo)
  totalValueCents Int        @default(0)
  updatedAt       DateTime   @updatedAt

  @@index([restaurantId])
}

/// Libro de movimientos — APPEND-ONLY. Correcciones = movimiento contrario.
/// qtyBase y valueCents llevan SIGNO (+entra / −sale).
model StockMovement {
  id                String            @id @default(cuid())
  restaurantId      String
  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  ingredientId      String
  ingredient        Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  kind              StockMovementKind
  qtyBase           Int
  valueCents        Int
  wasteReason       WasteReason?
  note              String?
  stockCountId      String?
  stockCount        StockCount?       @relation(fields: [stockCountId], references: [id], onDelete: SetNull)
  // A2: recepciones de OC — el libro ES el registro de recepción (spec D3).
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  // A4: consumo por venta — orden pagada que originó el sale_consumption.
  orderId           String?
  order             Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  // A5: producción — batch que originó el production_in/out.
  productionBatchId String?
  productionBatch   ProductionBatch?  @relation(fields: [productionBatchId], references: [id], onDelete: SetNull)
  createdById       String?
  createdBy         User?             @relation("StockMovementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())

  @@index([restaurantId, createdAt])
  @@index([ingredientId, createdAt])
  @@index([orderId])
  @@index([productionBatchId])
}

enum StockCountStatus {
  draft
  closed
}

/// Sesión de conteo físico. El teórico (expectedQty) se CONGELA al crear la
/// sesión; el cierre genera count_adjust por cada diferencia y deja el
/// reporte de desviación permanente. Máx. 1 sesión draft por comercio
/// (lo aplica la API).
model StockCount {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       StockCountStatus @default(draft)
  notes        String?
  createdById  String?
  createdBy    User?            @relation("StockCountCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  closedAt     DateTime?

  items     StockCountItem[]
  movements StockMovement[]

  @@index([restaurantId, status])
}

model StockCountItem {
  id           String     @id @default(cuid())
  countId      String
  count        StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  expectedQty  Int // snapshot del teórico al crear la sesión
  countedQty   Int? // null = todavía sin contar

  @@unique([countId, ingredientId])
}

// === ERP · Fase A2: compras (OCs, recepción, precios, CxP) =================
// Spec: docs/superpowers/specs/2026-07-04-erp-a2-compras-design.md
// Se pide en presentaciones del proveedor, se guarda en unidad base. La
// recepción genera purchase_in vía applyStockMovement (el libro ES el
// registro de recepción — StockMovement.purchaseOrderId). CxP acotada a
// compras: factura del proveedor + vencimiento + pagada en la propia OC.

enum PurchaseOrderStatus {
  draft
  sent
  partially_received
  received
  canceled
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  restaurantId String
  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  // Consecutivo por comercio ("OC-0007"), asignado max+1 en la tx de creación.
  number       Int
  status       PurchaseOrderStatus @default(draft)
  notes        String?
  expectedAt   DateTime? // entrega esperada
  sentAt       DateTime?
  receivedAt   DateTime? // recepción COMPLETA
  canceledAt   DateTime?

  // CxP (spec D5). invoiceDueAt default: receivedAt + paymentTermsDays.
  supplierInvoiceNumber String?
  invoiceDueAt          DateTime?
  // paidAt se setea cuando el saldo llega a 0 (pagada por completo).
  paidAt                DateTime?
  paymentNote           String?
  // Abonado acumulado (centavos) — cache mantenido en la tx de cada pago.
  // Saldo = total bruto de la OC − paidCents.
  paidCents             Int       @default(0)

  // Impuestos de la factura capturados/verificados por el operador (ERP A3).
  // El IVA se deriva de las líneas (taxPct); estos son los demás que la
  // factura discrimina a nivel documento, para la contabilidad/reportes.
  incCents        Int @default(0) // Impuesto al consumo (impoconsumo)
  retefuenteCents Int @default(0) // Retención en la fuente
  reteIvaCents    Int @default(0) // Retención de IVA
  reteIcaCents    Int @default(0) // Retención de ICA

  createdById String?
  createdBy   User?    @relation("PurchaseOrderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items          PurchaseOrderItem[]
  movements      StockMovement[]
  priceHistory   SupplierPriceHistory[]
  invoiceUploads PurchaseInvoiceUpload[]
  payments       PurchasePayment[]

  @@unique([restaurantId, number])
  @@index([restaurantId, status])
  @@index([restaurantId, invoiceDueAt])
}

model PurchaseOrderItem {
  id              String              @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient          @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  supplierItemId  String?
  supplierItem    SupplierIngredient? @relation(fields: [supplierItemId], references: [id], onDelete: SetNull)

  // Pedido (spec D2): SIEMPRE en unidad base; presentations solo cuando la
  // línea viene de la lista de precios (qtyOrderedBase = n × contentQty).
  qtyOrderedBase    Int
  presentations     Int?
  // NETO (sin IVA) esperado de la línea. Filas viejas: taxPct 0 ⇒ neto = bruto.
  expectedCostCents Int
  // IVA % de la línea (0/5/19 CO, 0/8/16 MX). El bruto se deriva: neto + IVA.
  taxPct            Int @default(0)

  // Acumulado por recepciones parciales (spec D3). Sobre-recepción permitida.
  receivedQtyBase   Int @default(0)
  // NETO acumulado recibido (sin IVA). El bruto de la CxP se deriva con taxPct.
  receivedCostCents Int @default(0)

  @@index([purchaseOrderId])
}

/// Abono (pago parcial o total) de una OC recibida — CxP (F3). Varios
/// por OC; el saldo = total bruto − Σ abonos. Cuando el saldo llega a 0
/// la OC queda pagada (PurchaseOrder.paidAt). Historial para auditoría.
model PurchasePayment {
  id              String        @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  amountCents     Int
  paidAt          DateTime // fecha del abono (editable)
  method          String? // efectivo / transferencia / … (texto libre)
  note            String?
  createdById     String?
  createdBy       User?    @relation("PurchasePaymentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([restaurantId, paidAt])
}

/// Historial de precios por presentación de la lista de precios (spec D4).
/// source: "reception" (recepción de OC) | "manual" (edición en la lista).
model SupplierPriceHistory {
  id              String             @id @default(cuid())
  supplierItemId  String
  supplierItem    SupplierIngredient @relation(fields: [supplierItemId], references: [id], onDelete: Cascade)
  priceCents      Int // por presentación
  source          String
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())

  @@index([supplierItemId, createdAt])
}

// === ERP · Fase A3: recetas y costeo =======================================
// Spec: docs/superpowers/specs/2026-07-05-erp-a3-recetas-design.md
// Receta 1:1 por plato (menuItemId) O sub-receta 1:1 por insumo elaborado
// (outputIngredientId + rendimiento). El costo NUNCA se persiste — se
// deriva en vivo con la cascada de src/lib/erp/recipes.ts (inventario →
// sub-receta → proveedor preferido → "incompleto").

model Recipe {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  menuItemId String?   @unique
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  outputIngredientId String?     @unique
  outputIngredient   Ingredient? @relation("IngredientRecipe", fields: [outputIngredientId], references: [id], onDelete: Cascade)
  outputQtyBase      Int? // rendimiento del batch (solo sub-receta)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         RecipeItem[]
  modifierItems ModifierRecipeItem[]

  @@index([restaurantId])
}

model RecipeItem {
  id           String     @id @default(cuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  /// Cantidad NETA al plato, en unidad base del insumo.
  qtyBase  Int
  /// Merma de preparación 0-90 (%). El costo usa bruto = neto / (1 − merma).
  wastePct Int @default(0)

  @@unique([recipeId, ingredientId])
}

/// Delta de insumo asociado a UNA opción de modificador de un plato (ej.
/// "extra queso" suma queso; "sin cebolla" resta cebolla). Se aplica al
/// consumo (A4) solo cuando el comensal eligió esa opción. Separado de
/// RecipeItem porque un mismo insumo puede estar en la receta base Y en una
/// opción (el @@unique de RecipeItem no lo permitiría), y para no alterar el
/// costo BASE del plato. `qtyBase` lleva SIGNO: + agrega, − quita.
model ModifierRecipeItem {
  id           String     @id @default(cuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  /// Id del grupo de modificador (MenuItem.modifiers[].id).
  modifierId String
  /// Label de la opción elegida (MenuItem.modifiers[].opts[].label).
  optLabel   String

  /// Delta NETO en unidad base del insumo. + agrega, − quita (nunca 0).
  qtyBase  Int
  /// Merma de preparación 0-90 (%). Mismo criterio que RecipeItem.
  wastePct Int @default(0)

  @@unique([recipeId, modifierId, optLabel, ingredientId])
  @@index([recipeId])
}

// === ERP · Fase A5: producción de batches ==================================
// Spec: docs/superpowers/specs/2026-07-06-erp-a5-produccion-traslados-design.md
// (traslados entre sedes descartados por decisión de producto). Un batch
// registra producción YA HECHA de una sub-receta: salen los ingredientes
// (production_out al promedio) y entra el elaborado (production_in con el
// costo exacto de lo que salió). El ledger es la verdad (movimientos con
// productionBatchId); sin edición — errores se corrigen con movimientos
// contrarios (regla A1).

model ProductionBatch {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Elaborado producido (la receta puede cambiar después; el ledger
  // conserva lo que realmente salió).
  outputIngredientId String
  outputIngredient   Ingredient @relation("BatchOutput", fields: [outputIngredientId], references: [id], onDelete: Restrict)
  // Cantidad producida, en unidad base del elaborado.
  outputQtyBase      Int
  // Σ consumos — lo que entró el production_in.
  costCents          Int
  note               String?

  createdById String?
  createdBy   User?    @relation("ProductionBatchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  movements StockMovement[]

  @@index([restaurantId, createdAt])
}

// === ERP · Fase C1: horarios, asistencia y costo laboral ===================
// Spec: docs/superpowers/specs/2026-07-07-erp-c1-horarios-design.md
// Empleados propios del comercio (no los usuarios del app — la mayoría
// del personal no tiene cuenta; los roles del app son de acceso, no de
// nómina) + turnos planeados con asistencia punchada encima. El costo
// laboral (real si está punchado, planeado si no) alimenta el prime
// cost del P&L (B2).

model Employee {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name            String
  // Cargo libre con datalist (criterio categorías de insumos/gastos).
  position        String
  // Salario básico mensual en centavos. null = sin salario: no aporta a
  // la base laboral del mes y se marca "sin salario" — nunca se inventa.
  // El valor de la hora ordinaria se DERIVA: salario / staffHoursDivisor
  // (recargos y horas extra). Es el input primario del costo laboral.
  monthlySalaryCents Int?
  // DEPRECADO (C1). Reemplazado por monthlySalaryCents; se deja un release
  // para no perder datos en `db push`. Backfill opcional en la VPS:
  // UPDATE "Employee" SET "monthlySalaryCents" = "hourlyRateCents" * 240
  //   WHERE "monthlySalaryCents" IS NULL AND "hourlyRateCents" IS NOT NULL;
  // Sin uso en el código desde el modelo de salario mensual.
  hourlyRateCents Int?
  active          Boolean @default(true)
  // Cuenta del app opcional (mesero con login). Hoy informativo; deja la
  // puerta abierta al self check-in.
  userId          String? @unique
  user            User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // C2 — plantilla semanal: [{weekday: 0-6 (0=lunes), ranges:
  // [{startMinutes, endMinutes}]}] (0-2 rangos/día, reglas de StaffShift).
  weeklyTemplate  Json?
  // C2 — reconocimiento facial en el navegador. DATO SENSIBLE (CO Ley
  // 1581 / MX LFPDPPP): descriptores de 128 floats (1-3) + fotos de
  // referencia; faceConsentAt registra el consentimiento informado.
  // "Eliminar registro facial" borra los tres.
  faceDescriptors Json?
  facePhotoUrls   Json?
  faceConsentAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts       StaffShift[]
  payrollItems PayrollItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId, active])
}

/// Corrida de nómina mensual (liquidación legal, portada de zenith-erp).
/// Una por comercio y mes; regenerable mientras esté en draft.
model PayrollRun {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  month        String // "YYYY-MM"
  status       String     @default("draft")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  items PayrollItem[]

  @@unique([restaurantId, month])
}

/// Concepto liquidado de un empleado en una corrida (snapshot).
model PayrollItem {
  id           String     @id @default(cuid())
  runId        String
  run          PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeName String
  conceptKey   String
  conceptLabel String
  kind         String // devengado | deduccion | aporte_empleador | provision
  amountCents  Int

  @@index([runId])
}

/// Turno planeado + asistencia (distinto del Shift de caja/arqueo).
model StaffShift {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Día al que pertenece el turno (medianoche UTC). Nocturnos cruzan
  // medianoche pero pertenecen al día en que EMPIEZAN.
  date         DateTime
  // Rango en minutos desde la medianoche de `date`: start 0-1439,
  // end > start y <= start+960 (máx. 16 h) — 18:00→02:00 es 1080→1560.
  startMinutes Int
  endMinutes   Int
  note         String?

  // Asistencia: timestamps reales del punch (ajustables a mano por el
  // operador). Ambos presentes => el costo usa los minutos reales.
  checkInAt        DateTime?
  checkOutAt       DateTime?
  // C2 — evidencia y origen del punch ("face" | "manual" | "operator").
  checkInPhotoUrl  String?
  checkOutPhotoUrl String?
  checkInMethod    String?
  checkOutMethod   String?
  // C2 — el cron cerró la salida a la hora planeada (olvido de check-out).
  autoClosed       Boolean   @default(false)

  // Revisión de identidad: se marca cuando un punch fue MANUAL con foto
  // (la cámara funcionó pero el reconocimiento facial no matcheó → alguien
  // eligió su nombre a mano). El admin revisa que la foto concuerde con la
  // persona; reviewedAt lo cierra.
  reviewNeededAt   DateTime?
  reviewedAt       DateTime?
  reviewedByEmail  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, date])
  @@index([employeeId, date])
  @@index([restaurantId, reviewNeededAt])
}

// === ERP · Fase A2.5: órdenes de compra desde factura (lectura IA) =========
// Spec: docs/superpowers/specs/2026-07-08-erp-a2-5-factura-compra-ia-design.md
// El operador sube el PDF/foto de una factura de proveedor; la IA la lee
// y arma una OC en borrador para revisar y confirmar. La imagen queda de
// evidencia ligada a la OC; la extracción cruda se guarda para reintentar.

model PurchaseInvoiceUpload {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  fileUrl    String
  status     String @default("pending") // pending | confirmed | discarded
  // Salida cruda de extractPurchaseInvoice (para re-abrir/editar).
  extraction Json

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([restaurantId, status])
}

// === ERP · Fase B1: facturación electrónica DIAN (software propio) =========
// Spec: docs/superpowers/specs/2026-07-07-erp-b1-dian-directo-design.md
// Integración DIRECTA con la DIAN (sin proveedor tecnológico). El emisor
// es la LegalEntity (grupos) o el Restaurant (independientes) — mismo
// criterio que la numeración DIAN. Certificado .p12, contraseña y PIN
// van ENCRIPTADOS at rest (AES-256-GCM con DIAN_MASTER_KEY del server).

model DianConfig {
  id String @id @default(cuid())

  legalEntityId String?      @unique
  legalEntity   LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: Cascade)
  restaurantId  String?      @unique
  restaurant    Restaurant?  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Certificado digital de firma (.p12) — ciphertext AES-256-GCM.
  certP12Enc      Bytes?
  certPasswordEnc String?
  // Derivados al subir (para avisos de vencimiento; no sensibles).
  certSubject     String?
  certNotAfter    DateTime?

  // Portal DIAN — software propio.
  softwareId     String?
  softwarePinEnc String? // encriptado (entra al CUDE)
  // Clave técnica de la resolución de numeración (entra al CUFE).
  technicalKey   String?
  testSetId      String?

  environment String @default("habilitacion") // habilitacion | produccion
  status      String @default("pending") // pending | testing | enabled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Tracking de un documento electrónico enviado a la DIAN. El estado y el
/// XML firmado viven acá; SimpleInvoice sigue siendo la representación
/// gráfica y enlaza 1:1.
model DianDocument {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  simpleInvoiceId String?        @unique
  simpleInvoice   SimpleInvoice? @relation(fields: [simpleInvoiceId], references: [id], onDelete: SetNull)

  kind  String @default("invoice") // invoice | credit_note
  state String @default("to_send") // to_send | sent | pending | accepted | rejected | error

  cufe        String?
  // XML firmado, comprimido (zip) — lo que se envió a la DIAN.
  xmlZip      Bytes?
  responseXml String?
  // zipKey/trackId del envío (asíncrono en habilitación).
  trackId     String?
  errors      Json?
  attempts    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, state])
}

// === ERP · Fase B2: gastos y contabilidad ==================================
// Spec: docs/superpowers/specs/2026-07-06-erp-b2-contabilidad-design.md
// Gasto operativo del comercio. Categoría LIBRE con datalist (criterio
// Ingredient.category — sin plan de cuentas impuesto). Un gasto puede ser
// plantilla mensual (recurring + recurringDay): el cron
// /api/cron/recurring-expenses lo materializa como copia con templateId,
// una sola vez por mes (idempotente).

model Expense {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  category    String
  description String?
  amountCents Int
  // Fecha CONTABLE del gasto (editable) — no confundir con createdAt.
  date        DateTime
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // Plantilla mensual (recurringDay 1-28, lo valida la API).
  recurring    Boolean @default(false)
  recurringDay Int?

  templateId String?
  template   Expense?  @relation("ExpenseTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  copies     Expense[] @relation("ExpenseTemplate")

  createdById String?
  createdBy   User?    @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([restaurantId, date])
  @@index([restaurantId, recurring])
}

// === Kushki integration ====================================================

enum KushkiDocumentKind {
  cedula_rep_legal
  rut
  camara_comercio
  bank_cert
  // Origen de fondos firmado por contador, requerido por compliance.
  origen_fondos
  // Estados financieros recientes del comercio.
  estados_financieros
  // estatutos sigue en el enum por compatibilidad con uploads previos;
  // dejó de pedirse desde la nueva versión del onboarding.
  estatutos
  other
}

enum KushkiDocumentStatus {
  pending
  verified
  rejected
}

model KushkiDocument {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?      @relation("KushkiDocumentUploader", fields: [uploadedById], references: [id])

  kind            KushkiDocumentKind
  status          KushkiDocumentStatus @default(pending)
  fileUrl         String
  fileName        String
  mimeType        String
  fileSize        Int
  // Structured fields extracted by Claude (only set for bank_cert today).
  extractedFields Json?
  reviewNotes     String?

  // Entrega por SFTP a AWS Transfer (carpeta por comercio). Best-effort: el
  // documento se guarda igual; un cron reintenta los que fallaron.
  // sftpUploadedAt null = pendiente/no subido; sftpError = último error.
  sftpUploadedAt  DateTime?
  sftpError       String?
  sftpAttempts    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, kind])
  @@index([sftpUploadedAt])
}

enum KushkiTransactionKind {
  charge
  refund
  dispersion
  fee
}

enum KushkiTransactionStatus {
  pending
  approved
  declined
  reversed
}

// Local mirror of every transaction we see in Kushki. Lets us render
// dashboards without round-tripping their API and provides a reconciliation
// audit trail. Webhook handlers upsert here on (kushkiTxId).
model KushkiTransaction {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  paymentId    String?
  payment      Payment?   @relation(fields: [paymentId], references: [id])

  kushkiTxId  String                  @unique
  kind        KushkiTransactionKind
  status      KushkiTransactionStatus
  amountCents Int
  currency    String                  @default("COP")
  raw         Json
  message     String?

  // Detalles ricos del cobro con tarjeta, extraídos del `fullResponse:"v2"` de
  // Kushki (viven también en `raw`, pero acá quedan en columnas legibles para
  // la vista de pagos del operador). Sólo se llenan en charges con tarjeta que
  // devuelven el bloque `details`. Todos nullable → aditivo, prisma db push.
  cardBrand      String? // Visa, Mastercard, ...
  cardLast4      String? // últimos 4 dígitos
  cardType       String? // CREDIT / DEBIT (crudo de Kushki)
  cardBin        String? // primeros 6 (BIN)
  cardHolderName String?
  approvalCode   String? // código de aprobación del emisor
  processorName  String? // procesador/adquirente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, createdAt])
}

enum WalletMovementKind {
  credit
  debit
  fee
  dispersion
  adjustment
}

model WalletMovement {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  kind              WalletMovementKind
  amountCents       Int
  balanceAfterCents Int
  currency          String             @default("COP")
  kushkiRef         String?
  description       String?
  occurredAt        DateTime

  createdAt DateTime @default(now())

  @@unique([restaurantId, kushkiRef])
  @@index([restaurantId, occurredAt])
}

enum PayoutStatus {
  initialized // Transfer Out iniciado (INITIALIZED de Kushki), aún sin liquidar
  approved // acreditado (webhook approvedTransaction)
  declined // rechazado por el banco (webhook declinedTransaction)
  failed // no se pudo ni iniciar (error de token/init) — registro informativo
}

/// Transfer Out (dispersión / retiro) que el comercio inicia desde la
/// billetera: hacia su propia cuenta del onboarding o hacia una cuenta de
/// terceros. Nace `initialized` en el init y lo actualiza el webhook de
/// payouts a approved/declined. El número de cuenta NO se guarda completo
/// (solo los últimos 4) — es PII y no hace falta para el historial.
model Payout {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  amountCents Int
  currency    String @default("COP")

  // Destino
  toOwnAccount Boolean @default(false) // true = cuenta propia registrada
  bankName     String
  bankId       String?
  accountType  String // "ahorros" | "corriente"
  accountLast4 String
  holderName   String

  status       PayoutStatus @default(initialized)
  providerRef  String? // transactionReference (uuid) de Kushki
  ticketNumber String? // ticketNumber numérico de Kushki
  reference    String? // nuestra referencia (mp-<ts>)
  responseText String? // mensaje de Kushki al liquidar (aprobada/rechazo)

  createdByEmail String?
  settledAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([restaurantId, createdAt])
  @@index([providerRef])
  @@index([ticketNumber])
}

model TerminalDevice {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  kushkiDeviceId String     @unique
  // Serial físico del datáfono (Kushki Cloud Terminal API / billpocket).
  // Es el identificador con el que se le hace push al equipo Ultra vía
  // POST /push-notifications { serialNumber }. Lo carga el comercio desde
  // Configuración → Datáfonos. null en devices legacy/mock.
  serialNumber   String?
  label          String
  active         Boolean    @default(true)
  lastSeenAt     DateTime?
  assignedUserId String?
  assignedUser   User?      @relation(fields: [assignedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, active])
}

// Idempotency log for Kushki webhooks. eventId is whatever unique value
// their callback header gives us; we reject duplicates by returning 200
// without reprocessing.
model KushkiWebhookEvent {
  id           String      @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  eventId      String      @unique
  type         String
  payload      Json
  processedAt  DateTime?
  error        String?
  createdAt    DateTime    @default(now())

  @@index([type, createdAt])
}

enum InvoiceDocType {
  CC
  CE
  NIT
  PA
}

enum InvoiceRequestStatus {
  pending
  generated
  rejected
}

// Customer-submitted billing info captured after payment. The restaurant
// still has to push it through their own invoicing software (Siigo,
// Alegra, etc.). We just store the data and track which ones have been
// emitted so nothing falls through the cracks.
// "Factura simple" — tirilla tipo POS enviada por correo al cliente
// que no requiere factura con razón social / NIT específico, solo
// el comprobante con campos DIAN. Distinto a InvoiceRequest (la
// formal, donde se capturan datos para que el operador la emita
// en su software contable).
//
// Se auto-genera y auto-envía al confirmar pago: el cliente escribe
// su email post-payment, asignamos consecutivo de
// Restaurant.invoiceNextNumber (atomic increment), guardamos la
// row + mandamos correo con link a /factura/[id]. Si el envío de
// email falla quedamos con la row + emailedAt=null para reintento
// manual.
model SimpleInvoice {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderId      String     @unique
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Opcional: si no se deja correo, la factura solo se imprime/descarga.
  email         String?
  // Consecutivo asignado al momento de emitir. Para DIAN se concatena
  // con Restaurant.invoicePrefix al renderear (ej: POS-42).
  invoiceNumber Int
  // Snapshot completo de la identidad legal + DIAN del comercio al
  // momento de emitir. Si el operador cambia los datos después, la
  // factura ya emitida conserva el contexto histórico.
  snapshot      Json
  // Total al momento de emitir (food + tip), en cents. Snapshot
  // contra cambios futuros en la orden.
  totalCents    Int
  emailedAt     DateTime?
  emailError    String?

  dianDocument DianDocument?

  createdAt DateTime @default(now())

  @@index([restaurantId, createdAt])
}

model InvoiceRequest {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  customerName String
  docType      InvoiceDocType
  docNumber    String
  address      String
  city         String
  department   String
  email        String

  // For audit + future API integrations — keep the raw Google Place when
  // available so we can re-derive components if our parsing was off.
  placeId       String?
  rawComponents Json?

  status           InvoiceRequestStatus @default(pending)
  generatedAt      DateTime?
  generatedByEmail String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, status, createdAt])
  @@index([orderId])
}

/**
 * Traducciones de CONTENIDO cargado por cada restaurante (no de la UI).
 * Los nombres/descripciones de platos, categorías, etiquetas, etc. viven
 * en español en sus modelos. Esto NO se puede traducir con catálogos
 * estáticos. Acá guardamos la traducción por (entidad, campo, idioma),
 * generada on-demand con IA (ver src/lib/translateContent.ts) y cacheada.
 * - source: "machine" (IA) | "human" (editada por el operador).
 * - sourceHash: hash del texto original al momento de traducir; si el
 * operador cambia el original, detectamos que la traducción quedó
 * obsoleta y la regeneramos.
 * Tabla genérica a propósito: agregar un modelo traducible nuevo no
 * requiere migración, sólo pasar su entityType.
 */
model Translation {
  id         String   @id @default(cuid())
  entityType String // "MenuItem" | "Category" | "Menu" | "MenuTag" | ...
  entityId   String
  field      String // "name" | "description" | "label"
  locale     String // "en" | "pt" (nunca "es": es el original)
  value      String
  source     String   @default("machine")
  sourceHash String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId, field, locale])
  @@index([entityType, entityId])
}

model AiConversation {
  id           String      @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  groupId      String?
  userId       String
  title        String      @default("Nueva conversación")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  messages     AiMessage[]

  @@index([restaurantId, userId])
  @@index([groupId, userId])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String
  toolCalls      Json?
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

model SearchEvent {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  term         String
  rawTerm      String
  resultCount  Int
  hadResults   Boolean
  locale       String?
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([restaurantId, term])
}

// ═══════════════════════════════════════════════════════════════════════════
//  CRM MESAPAY
//  Módulo de gestión comercial: leads, contactos, actividades, citas,
//  documentos, plantillas de email y configuración de países/ciudades.
// ═══════════════════════════════════════════════════════════════════════════

/// Etapas del pipeline comercial (espejo de Kommo validado).
/// perdido exige lostReason en CrmLead.
enum CrmStage {
  nuevo
  contactado
  demo_agendada
  demo_realizada
  propuesta_enviada
  negociacion
  ganado
  perdido
}

/// Lead comercial — el corazón del CRM.
/// Un lead es un restaurante potencial que el comercial está trabajando.
model CrmLead {
  id           String   @id @default(cuid())
  name         String
  countryCode  String // ISO-2 (CO, MX, …)
  cityId       String? // → CrmCity
  city         CrmCity? @relation(fields: [cityId], references: [id], onDelete: SetNull)
  address      String?
  zone         String? // barrio / zona comercial
  businessType String? // tipo de negocio (restaurante, cafetería, etc.)
  stage        CrmStage @default(nuevo)
  priority     String   @default("b") // a | b | c
  source       String? // cómo llegó el lead: directo, referido, csv, etc.
  planProposed String? // plan que se le propone (trial, basic, pro)
  unitsCount   Int? // número de locales (para cadenas)
  unitNames    String[] @default([]) // nombres de los restaurantes/marcas del grupo

  // Asignación + creación
  assignedToUserId String
  assignedTo       User   @relation("CrmAssigned", fields: [assignedToUserId], references: [id])
  createdByUserId  String
  createdBy        User   @relation("CrmCreated", fields: [createdByUserId], references: [id])

  // Seguimiento temporal
  nextActionAt   DateTime?
  lastActivityAt DateTime?

  // Cierre
  lostReason   String?
  notes        String?
  // Cuando se gana, se vincula al restaurante creado en MESAPAY
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts     CrmContact[]
  activities   CrmActivity[]
  appointments CrmAppointment[]

  @@index([assignedToUserId, stage])
  @@index([assignedToUserId, nextActionAt])
  @@index([countryCode])
}

/// Contacto de un lead. Puede haber varios; uno es principal.
model CrmContact {
  id        String  @id @default(cuid())
  leadId    String
  lead      CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name      String
  role      String? // cargo: dueño, gerente, chef, etc.
  phone     String? // E.164
  email     String?
  isPrimary Boolean @default(false)
  notes     String?

  @@index([leadId])
}

/// Actividad registrada en el timeline de un lead.
/// type: note | call | whatsapp | email | visit | stage_change | appointment
model CrmActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // note | call | whatsapp | email | visit | stage_change | appointment
  content   String
  meta      Json? // metadata extra: asunto de email, de/para en stage_change, etc.
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

/// Cita agendada con el prospecto.
/// status: scheduled | done | cancelled
model CrmAppointment {
  id         String    @id @default(cuid())
  leadId     String
  lead       CrmLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  title      String
  startsAt   DateTime
  endsAt     DateTime
  notes      String?
  remindedAt DateTime? // cuándo se envió el push-recordatorio
  status     String    @default("scheduled") // scheduled | done | cancelled

  @@index([userId, startsAt])
  @@index([leadId])
}

/// Documento compartido (PDF, imagen) que los comerciales adjuntan a plantillas.
/// scope: global (todos) | user (solo el dueño).
model CrmDocument {
  id          String   @id @default(cuid())
  name        String
  fileUrl     String
  mime        String
  size        Int // bytes
  scope       String   @default("global") // global | user
  ownerUserId String?
  owner       User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([ownerUserId])
}

/// Plantilla de email con variables {{nombre}} {{comercio}} {{ciudad}} {{comercial}}.
/// attachmentIds: IDs de CrmDocument que se adjuntan.
/// scope: global | user
model CrmEmailTemplate {
  id            String   @id @default(cuid())
  name          String
  subject       String
  bodyHtml      String
  attachmentIds String[] @default([]) // IDs de CrmDocument
  scope         String   @default("global") // global | user
  ownerUserId   String?
  owner         User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerUserId])
}

/// Plantilla de mensaje de WhatsApp con variables {{nombre}} {{comercio}}
/// {{ciudad}} {{comercial}}. `body` es texto plano que se renderiza en el
/// cliente y se abre en WhatsApp como mensaje prellenado.
/// scope: global | user
model CrmWhatsappTemplate {
  id          String   @id @default(cuid())
  name        String
  body        String
  scope       String   @default("global") // global | user
  ownerUserId String?
  owner       User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId])
}

/// Cuenta SMTP personal del comercial para enviar correos desde el CRM.
/// smtpPassEnc: contraseña cifrada con AES (src/lib/crypto.ts).
model CrmEmailAccount {
  userId      String    @id // un usuario, una cuenta
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromName    String
  email       String
  smtpHost    String
  smtpPort    Int
  smtpUser    String
  smtpPassEnc String // AES-GCM ciphertext
  verifiedAt  DateTime? // se setea cuando el test de envío pasa OK

  @@index([userId])
}

/// País activo en el CRM. Cuando enabled=true se cargan las ciudades
/// desde el dataset estático en src/data/cities/{code.toLowerCase()}.json.
model CrmCountry {
  code     String  @id // ISO-2 (CO, MX, …)
  name     String
  enabled  Boolean @default(false)
  currency String  @default("COP") // ISO-4217 de cobro del país (COP, MXN). Fuente única para suscripción y pagos.

  cities CrmCity[]
}

/// Ciudad/municipio del país. isMain marca las top-5 que aparecen
/// primero en el combobox del formulario de lead.
model CrmCity {
  id          String     @id @default(cuid())
  countryCode String
  country     CrmCountry @relation(fields: [countryCode], references: [code], onDelete: Cascade)
  name        String
  isMain      Boolean    @default(false)

  leads CrmLead[]

  @@unique([countryCode, name])
  @@index([countryCode, name])
}

// ─────────────────────── Contabilidad (doble partida) ───────────────────────
// Fase 1: plan de cuentas (PUC NIIF Grupo 2) + estructura de asientos. El motor
// que genera asientos automáticos vive en fases siguientes; estos modelos son
// la fundación. Todo por comercio (multi-tenant).

enum LedgerAccountType {
  activo
  pasivo
  patrimonio
  ingreso
  gasto
  costo
}

enum LedgerAccountNature {
  debito
  credito
}

/// Cuenta del plan contable (PUC). Jerárquico por longitud de código:
/// 1=clase, 2=grupo, 4=cuenta, 6=subcuenta. Sólo las hojas (`postable`)
/// reciben movimientos; las agrupadoras suman a sus hijas.
model LedgerAccount {
  id           String              @id @default(cuid())
  restaurantId String
  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  code         String
  name         String
  type         LedgerAccountType
  nature       LedgerAccountNature
  level        Int
  parentCode   String?
  postable     Boolean             @default(false)
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())

  lines JournalLine[]

  @@unique([restaurantId, code])
  @@index([restaurantId, code])
}

/// Comprobante contable (asiento). Sus líneas suman débito == crédito.
/// `source`+`sourceRef` dan idempotencia: un solo asiento por hecho económico.
model JournalEntry {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime
  source       String
  sourceRef    String?
  memo         String?
  status       String     @default("posted")
  createdAt    DateTime   @default(now())

  lines JournalLine[]

  @@unique([restaurantId, source, sourceRef])
  @@index([restaurantId, date])
}

/// Movimiento de un asiento: débito O crédito sobre una cuenta.
model JournalLine {
  id          String        @id @default(cuid())
  entryId     String
  entry       JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String
  account     LedgerAccount @relation(fields: [accountId], references: [id])
  accountCode String
  debitCents  Int           @default(0)
  creditCents Int           @default(0)
  memo        String?

  @@index([entryId])
  @@index([accountId])
}
